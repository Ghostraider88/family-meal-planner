# syntax=docker/dockerfile:1
# Multi-stage production build: Vite build + Nginx serve.

FROM node:26-alpine AS builder
WORKDIR /app
ENV NODE_ENV=production

COPY package.json package-lock.json ./
RUN npm ci

COPY . .
# Build with /api as default API base (same-origin behind Nginx)
ENV VITE_API_URL=/api
RUN npm run build

FROM nginx:1.29-alpine AS runtime

# Drop default config; ours is mounted from build context
RUN rm /etc/nginx/conf.d/default.conf
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy built assets
COPY --from=builder /app/dist /usr/share/nginx/html

# Static health endpoint
RUN printf "ok\n" > /usr/share/nginx/html/health.txt

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://127.0.0.1/health.txt >/dev/null 2>&1 || exit 1

CMD ["nginx", "-g", "daemon off;"]
