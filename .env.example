# ============================================================================
# Family Meal Planner — Environment Example
# Copy to .env and fill in real values for production deployment.
# NEVER commit a real .env file. Use `openssl rand -base64 48` to generate
# strong secrets for JWT_SECRET and JWT_REFRESH_SECRET.
# ============================================================================

# --- Postgres ---------------------------------------------------------------
POSTGRES_DB=family_meal_planner
POSTGRES_USER=planner_user
# Use a strong, unique password (minimum 16 characters recommended).
POSTGRES_PASSWORD=replace_with_strong_random_password

# --- Backend Database connection -------------------------------------------
# In production these typically mirror the POSTGRES_* values above.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=family_meal_planner
DB_USER=planner_user
DB_PASSWORD=replace_with_strong_random_password
# Set to "true" only when connecting to a managed Postgres that requires SSL.
DB_SSL=false

# --- JWT --------------------------------------------------------------------
# REQUIRED in production. Min 32 chars. JWT_SECRET and JWT_REFRESH_SECRET
# MUST differ. Generate with: openssl rand -base64 48
JWT_SECRET=replace_with_random_32_plus_char_secret_for_access_tokens
JWT_REFRESH_SECRET=replace_with_different_random_32_plus_char_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- HTTP / CORS / Cookies --------------------------------------------------
# Origin from which the frontend is served. In selfhost setups typically the
# host and port behind your reverse proxy, e.g. http://meal.local:8087 or
# https://meal.example.com. CORS rejects everything else.
CORS_ORIGIN=http://localhost:8087
FRONTEND_URL=http://localhost:8087
# Production behind HTTPS: true. Plain HTTP in LAN: false.
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax

# --- Reverse proxy ----------------------------------------------------------
# express trust proxy. Options: false | true | "loopback" | numeric hops.
# Behind Nginx in same Docker network: "loopback".
TRUST_PROXY=loopback

# --- Rate limiting ----------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=info

# --- Frontend port (host) ---------------------------------------------------
# Only the frontend publishes a host port in production.
FRONTEND_PORT=8087

# --- SMTP (optional, for invites) ------------------------------------------
SMTP_SERVICE=
SMTP_USER=
SMTP_PASSWORD=

# ============================================================================
# Optional: Docker secret-file alternatives. Set *_FILE to a path inside the
# container and the matching value will be read from that file instead of
# the env variable. Useful with Docker Compose `secrets:` blocks.
# ============================================================================
# DB_PASSWORD_FILE=/run/secrets/db_password
# JWT_SECRET_FILE=/run/secrets/jwt_secret
# JWT_REFRESH_SECRET_FILE=/run/secrets/jwt_refresh_secret
# SMTP_PASSWORD_FILE=/run/secrets/smtp_password
