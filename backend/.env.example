# Backend-only env example. For full deployment env (incl. compose),
# see /.env.example at the repository root.

NODE_ENV=development
PORT=3001

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=family_meal_planner
DB_USER=planner_user
DB_PASSWORD=replace_me
DB_SSL=false

# JWT — generate with: openssl rand -base64 48
# Min 32 chars, MUST differ between access and refresh.
JWT_SECRET=replace_with_random_32_plus_char_secret_for_access_tokens
JWT_REFRESH_SECRET=replace_with_different_random_32_plus_char_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# HTTP / CORS
CORS_ORIGIN=http://localhost:8087
FRONTEND_URL=http://localhost:8087
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
TRUST_PROXY=loopback

# Rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=info

# SMTP (optional)
SMTP_SERVICE=
SMTP_USER=
SMTP_PASSWORD=
