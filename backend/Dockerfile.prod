# syntax=docker/dockerfile:1
# Multi-stage production build for the backend API.
# Produces a slim image with only production dependencies and non-root user.

FROM node:20-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --omit=dev && npm cache clean --force

FROM node:20-alpine AS runtime
ENV NODE_ENV=production
ENV PORT=3001

# tini provides proper signal forwarding for graceful shutdown
RUN apk add --no-cache tini wget

WORKDIR /app

# Use the built-in non-root "node" user
COPY --from=deps --chown=node:node /app/node_modules ./node_modules
COPY --chown=node:node package.json package-lock.json ./
COPY --chown=node:node src ./src
COPY --chown=node:node migrations ./migrations
COPY --chown=node:node .sequelizerc ./.sequelizerc

USER node

EXPOSE 3001

# Node-based healthcheck (no curl dependency)
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD wget -qO- http://127.0.0.1:3001/api/health || exit 1

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "src/app.js"]
