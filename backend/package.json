{
  "name": "family-meal-planner-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend API for Family Meal Planner",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "test": "node --test --test-reporter=spec \"test/*.test.js\"",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:status": "sequelize-cli db:migrate:status",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:undo": "sequelize-cli db:seed:undo:all"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pdf-parse": "^2.4.5",
    "pg": "^8.10.0",
    "sequelize": "^6.35.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.2.2"
  }
}
